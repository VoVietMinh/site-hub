{
  "name": "ee-control-panel",
  "version": "1.0.0",
  "description": "Internal web control panel to manage WordPress sites via EasyEngine and automate SEO content publishing.",
  "main": "src/app.js",
  "scripts": {
    "start": "node dist/app.js",
    "build": "tsc --project tsconfig.json",
    "dev": "ts-node src/app.ts",
    "dev:watch": "nodemon --exec ts-node src/app.ts --ext ts,ejs",
    "migrate": "ts-node src/infrastructure/db/migrate.ts",
    "seed": "ts-node src/infrastructure/db/seed.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@google/genai": "^2.0.1",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "i18n": "^0.15.1",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-flash": "^0.0.40",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/i18n": "^0.13.12",
    "@types/method-override": "^0.0.35",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.40",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
