'use strict';

const { query, queryOne, execute } = require('../../infrastructure/db/connection');

async function findByDomain(domain) {
  return queryOne('SELECT * FROM sites WHERE domain = $1', [domain]);
}

async function findById(id) {
  return queryOne('SELECT * FROM sites WHERE id = $1', [id]);
}

async function listAll() {
  return query('SELECT * FROM sites ORDER BY created_at DESC');
}

async function upsert({
  domain, site_type = 'wp', ssl = false, status = 'unknown',
  title = null, description = null, created_by = null,
  wp_user = null, wp_pass = null
}) {
  return queryOne(
    `INSERT INTO sites (domain, site_type, ssl, status, title, description, created_by, wp_user, wp_pass)
     VALUES ($1, $2, $3, $4, $5, $6, $7, $8, $9)
     ON CONFLICT (domain) DO UPDATE SET
       site_type   = EXCLUDED.site_type,
       ssl         = EXCLUDED.ssl,
       status      = EXCLUDED.status,
       title       = COALESCE(EXCLUDED.title,       sites.title),
       description = COALESCE(EXCLUDED.description, sites.description),
       wp_user     = COALESCE(EXCLUDED.wp_user,     sites.wp_user),
       wp_pass     = COALESCE(EXCLUDED.wp_pass,     sites.wp_pass),
       updated_at  = NOW()
     RETURNING *`,
    [domain, site_type, \!\!ssl, status, title, description, created_by || null, wp_user || null, wp_pass || null]
  );
}

async function updateCredentials(domain, wp_user, wp_pass) {
  await execute(
    'UPDATE sites SET wp_user = $1, wp_pass = $2, updated_at = NOW() WHERE domain = $3',
    [wp_user || null, wp_pass || null, domain]
  );
  return findByDomain(domain);
}

async function remove(domain) {
  return execute('DELETE FROM sites WHERE domain = $1', [domain]);
}

module.exports = { findByDomain, findById, listAll, upsert, updateCredentials, remove };
