<div class="page-header">
  <div>
    <h1 class="page-title"><%= site.domain %></h1>
    <p class="page-subtitle"><%= __('sites.createdSubtitle') %></p>
  </div>
  <div class="row-actions">
    <a href="/sites/<%= encodeURIComponent(site.domain) %>" class="btn"><%= __('sites.view') %></a>
    <a href="/sites" class="btn"><%= __('common.back') %></a>
  </div>
</div>

<div class="flash-item flash-success" style="margin-bottom:14px;">
  <%= __('sites.created', { domain: site.domain }) %>
</div>

<div class="card">
  <div class="card-header">
    <h3><%= __('sites.adminCredentials') %></h3>
    <span class="tag tag-yellow"><%= __('sites.shownOnce') %></span>
  </div>
  <div class="card-body">
    <p class="muted" style="margin-top:0;"><%= __('sites.copyNow') %></p>
    <div class="form-grid">
      <div>
        <div class="muted" style="font-size:12px;"><%= __('sites.frontUrl') %></div>
        <div><a href="<%= credentials.url %>" target="_blank" rel="noopener"><%= credentials.url %></a></div>
      </div>
      <div>
        <div class="muted" style="font-size:12px;"><%= __('sites.adminUrl') %></div>
        <div><a href="<%= credentials.adminUrl %>" target="_blank" rel="noopener"><%= credentials.adminUrl %></a></div>
      </div>
      <div>
        <div class="muted" style="font-size:12px;"><%= __('users.username') %></div>
        <div class="code" style="display:inline-block;"><%= credentials.user %></div>
      </div>
      <div>
        <div class="muted" style="font-size:12px;"><%= __('users.email') %></div>
        <div class="code" style="display:inline-block;"><%= credentials.email %></div>
      </div>
      <div style="grid-column: 1 / -1;">
        <div class="muted" style="font-size:12px;">
          <%= __('users.password') %>
          <% if (credentials.passwordGenerated) { %>
            <span class="tag tag-blue"><%= __('sites.autoGenerated') %></span>
          <% } %>
        </div>
        <div class="code" style="display:flex; align-items:center; gap:10px;">
          <span id="pw-text"><%= credentials.password %></span>
          <button type="button" class="btn btn-sm" onclick="navigator.clipboard.writeText(document.getElementById('pw-text').textContent)"><%= __('common.copy') %></button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><h3><%= __('sites.configurationApplied') %></h3></div>
  <div class="card-body">
    <div class="form-grid">
      <div>
        <div class="muted" style="font-size:12px;"><%= __('sites.theme') %></div>
        <div><span class="tag tag-blue"><%= cfg.theme %></span></div>
      </div>
      <div>
        <div class="muted" style="font-size:12px;"><%= __('sites.menu') %></div>
        <div>
          <span class="tag"><%= cfg.menuName %></span>
          <% if (cfg.menuLocation) { %>
            → <span class="tag tag-green"><%= cfg.menuLocation %></span>
          <% } else { %>
            <span class="muted" style="font-size:12px;">(<%= __('sites.menuNotAssigned') %>)</span>
          <% } %>
          <% if (cfg.isBlockTheme) { %>
            <div style="margin-top:6px;">
              <span class="tag tag-pink">Block theme (FSE)</span>
              <% if (cfg.blockNavigation && cfg.blockNavigation.ids && cfg.blockNavigation.ids.length) { %>
                <span class="muted" style="font-size:12px;">
                  wp_navigation
                  <%= cfg.blockNavigation.created ? 'created' : 'updated' %>:
                  #<%= cfg.blockNavigation.ids.join(', #') %>
                </span>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
      <div style="grid-column: 1 / -1;">
        <div class="muted" style="font-size:12px;"><%= __('sites.plugins') %></div>
        <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:4px;">
          <% (cfg.plugins || []).forEach(function(p){ %>
            <% if (p.ok) { %>
              <span class="tag tag-green"><%= p.slug %></span>
            <% } else { %>
              <span class="tag tag-red" title="<%= p.error %>"><%= p.slug %></span>
            <% } %>
          <% }) %>
        </div>
      </div>
      <div style="grid-column: 1 / -1;">
        <div class="muted" style="font-size:12px;"><%= __('sites.pages') %></div>
        <table class="table" style="margin-top:6px;">
          <thead>
            <tr>
              <th>ID</th>
              <th><%= __('sites.slug') %></th>
              <th><%= __('sites.menuTitle') %></th>
            </tr>
          </thead>
          <tbody>
            <% (cfg.pages || []).forEach(function(p){ %>
              <tr>
                <td><%= p.id %></td>
                <td><span class="code" style="display:inline-block;"><%= p.slug %></span></td>
                <td><%= p.menuTitle %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
