<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<style>
/* ── Editor ──────────────────────────────────────────────────────────────── */
.ql-container { font-size: 14px; min-height: 420px; }
.ql-toolbar   { border-radius: 6px 6px 0 0; }
.ql-container { border-radius: 0 0 6px 6px; }
.editor-tabs  { display: flex; gap: 0; margin-bottom: -1px; position: relative; z-index: 1; }
.editor-tab   { padding: 6px 16px; font-size: 13px; cursor: pointer; border: 1px solid #e5e7eb;
                border-bottom: none; border-radius: 6px 6px 0 0; background: #f9fafb; color: #6b7280; }
.editor-tab.active { background: #fff; color: #111827; font-weight: 600; }
#html-source  { display: none; width: 100%; box-sizing: border-box;
                font-family: monospace; font-size: 12px; line-height: 1.5;
                min-height: 460px; border: 1px solid #e5e7eb; border-radius: 0 0 6px 6px;
                padding: 12px; resize: vertical; }
/* ── Connection card ─────────────────────────────────────────────────────── */
.conn-row     { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.conn-dot     { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.conn-dot-ok  { background: #22c55e; }
.conn-dot-err { background: #ef4444; }
.conn-dot-unk { background: #d1d5db; }
.conn-dot-spin{ background: #f59e0b; animation: spin-border .7s linear infinite; }
@keyframes spin-border { to { transform: rotate(360deg); } }
.conn-detail  { font-size: 12px; color: #6b7280; }
.conn-detail span { margin-right: 12px; }
/* ── Category chip ───────────────────────────────────────────────────────── */
.cat-count    { font-size: 11px; color: #6b7280; margin-left: 4px; }
</style>

<div class="page-header">
  <div>
    <h1 class="page-title"><%= keyword.keyword %></h1>
    <p class="page-subtitle">
      Job #<%= job.id %> &middot; <%= job.topic %> &middot;
      <span class="tag <%=
        keyword.status === 'PUBLISHED'   ? 'tag-green'  :
        keyword.status === 'ERROR'       ? 'tag-red'    :
        keyword.status === 'GENERATED'   ? 'tag-blue'   :
        keyword.status === 'PENDING'     ? ''            : 'tag-yellow'
      %>"><%= keyword.status %></span>
    </p>
  </div>
  <a href="/content/<%= job.id %>" class="btn">&larr; Back to Job</a>
</div>

<% if (keyword.error_message) { %>
<div class="flash-item flash-error" style="margin-bottom:16px;"><%= keyword.error_message %></div>
<% } %>

<!-- ── Publish Site card ──────────────────────────────────────────────────── -->
<div class="card" style="margin-bottom:16px;">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
    <h3 style="margin:0;">Publish Site</h3>
    <% if (typeof site !== 'undefined' && site) { %>
    <button type="button" class="btn btn-sm" id="btn-check-conn" onclick="checkConnection()">
      Check Connection
    </button>
    <% } %>
  </div>
  <div class="card-body" style="padding-top:10px;">
    <% if (typeof site !== 'undefined' && site) { %>
    <div class="conn-row" style="margin-bottom:8px;">
      <div class="conn-dot conn-dot-unk" id="conn-dot"></div>
      <strong style="font-size:14px;">
        <% if (site.ssl) { %><span title="HTTPS">🔒</span><% } %>
        <%= site.domain %>
      </strong>
      <span id="conn-label" class="muted" style="font-size:13px;">Not checked</span>
    </div>
    <div class="conn-detail" id="conn-detail">
      <span>User: <strong><%= site.wpUser || '—' %></strong></span>
      <span>SSL: <strong><%= site.ssl ? 'Yes' : 'No' %></strong></span>
      <% if (!site.hasCreds) { %>
      <span style="color:#ef4444;">⚠ No WP credentials saved —
        <a href="/sites/<%= site.domain %>" style="color:inherit;text-decoration:underline;">set them in Sites</a>
      </span>
      <% } %>
    </div>
    <div id="conn-site-info" style="display:none;margin-top:8px;font-size:13px;color:#374151;"></div>
    <% } else { %>
    <p class="muted" style="margin:0;">
      No WordPress site bound to this job.
      <a href="/content/<%= job.id %>">Edit job</a> to assign one.
    </p>
    <% } %>
  </div>
</div>

<!-- ── Edit Content card ──────────────────────────────────────────────────── -->
<div class="card">
  <div class="card-header"><h3>Edit Content</h3></div>
  <div class="card-body">
    <form id="kw-form" method="post" action="/content/<%= job.id %>/keywords/<%= keyword.id %>">
      <input type="hidden" name="_return" value="keyword" />

      <div class="form-row">
        <label for="kw-title">Post Title</label>
        <input type="text" id="kw-title" name="title" value="<%= keyword.title || '' %>" style="width:100%;" />
      </div>

      <!-- ── HTML Editor ───────────────────────────────────────────────── -->
      <div class="form-row" style="margin-top:14px;">
        <label>Content</label>
        <div class="editor-tabs">
          <div class="editor-tab active" id="tab-visual" onclick="switchTab('visual')">Visual</div>
          <div class="editor-tab" id="tab-html" onclick="switchTab('html')">HTML Source</div>
        </div>
        <div id="quill-editor"></div>
        <textarea id="html-source" spellcheck="false"></textarea>
        <!-- Hidden field synced before submit -->
        <input type="hidden" id="kw-content" name="content" />
      </div>

      <!-- ── Meta row ──────────────────────────────────────────────────── -->
      <div style="display:flex;gap:16px;margin-top:14px;flex-wrap:wrap;">

        <!-- Category with live WP API select -->
        <div class="form-row" style="flex:2;min-width:220px;">
          <label>Category
            <span class="cat-count" id="cat-count"></span>
          </label>
          <div style="display:flex;gap:6px;align-items:center;">
            <select id="kw-category" name="category" style="flex:1;"
                    data-current="<%= keyword.category || '' %>">
              <option value="<%= keyword.category || '' %>">
                <%= keyword.category || '— loading…' %>
              </option>
            </select>
            <button type="button" class="btn btn-sm" id="btn-reload-cats"
                    onclick="loadCategories()" title="Reload from WordPress">↻</button>
          </div>
          <div style="display:flex;gap:6px;align-items:center;margin-top:6px;">
            <input type="text" id="kw-cat-new" placeholder="Or type a new category name…"
                   style="flex:1;font-size:13px;" autocomplete="off"
                   oninput="syncCatSelect(this.value)" />
          </div>
          <p id="cat-status" class="muted" style="font-size:11px;margin:4px 0 0;display:none;"></p>
          <p class="muted" style="font-size:11px;margin:4px 0 0;">
            Select an existing category or type a new name — it will be created automatically on publish.
          </p>
        </div>

        <div class="form-row" style="flex:1;min-width:160px;">
          <label for="kw-publish-status">Publish Status</label>
          <select id="kw-publish-status" name="publish_status" style="width:100%;">
            <option value="publish" <%= keyword.publish_status === 'publish' ? 'selected' : '' %>>publish</option>
            <option value="draft"   <%= keyword.publish_status === 'draft'   ? 'selected' : '' %>>draft</option>
            <option value="pending" <%= keyword.publish_status === 'pending' ? 'selected' : '' %>>pending</option>
          </select>
        </div>

        <div class="form-row" style="flex:1;min-width:160px;">
          <label for="kw-tone">Tone</label>
          <input type="text" id="kw-tone" name="tone"
                 value="<%= keyword.tone || '' %>" style="width:100%;" />
        </div>
      </div>

      <div class="form-actions" style="margin-top:16px;">
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<% if ((keyword.status === 'GENERATED' || keyword.status === 'ERROR') && keyword.content) { %>
<div class="card" style="margin-top:16px;">
  <div class="card-header"><h3>Publish to WordPress</h3></div>
  <div class="card-body">
    <p class="muted" style="margin:0 0 12px;">
      Save any edits first, then publish via the WordPress REST API
      (<code>POST /wp-json/wp/v2/posts</code>).
    </p>
    <form method="post" action="/content/<%= job.id %>/keywords/<%= keyword.id %>/publish">
      <button type="submit" class="btn btn-primary">Publish Now</button>
    </form>
  </div>
</div>
<% } %>

<% if (keyword.post_link) { %>
<div class="card" style="margin-top:16px;">
  <div class="card-header"><h3>Published Post</h3></div>
  <div class="card-body">
    <a href="<%= keyword.post_link %>" target="_blank" rel="noopener" class="btn btn-primary">
      View Post &rarr;
    </a>
    <span class="muted" style="margin-left:12px;font-size:13px;word-break:break-all;">
      <%= keyword.post_link %>
    </span>
  </div>
</div>
<% } %>

<% if (keyword.images_json) { %>
<% var _imgs = []; try { _imgs = JSON.parse(keyword.images_json); } catch(e) {} %>
<% if (_imgs.length) { %>
<div class="card" style="margin-top:16px;">
  <div class="card-header"><h3>Image Suggestions (<%= _imgs.length %>)</h3></div>
  <div class="card-body">
    <div style="display:flex;flex-wrap:wrap;gap:12px;">
      <% _imgs.forEach(function(img) { %>
      <div style="width:180px;">
        <img src="<%= img.url %>" alt="<%= img.title || '' %>"
             style="width:100%;height:120px;object-fit:cover;border-radius:4px;border:1px solid #e5e7eb;"
             onerror="this.parentNode.style.display='none'" />
        <% if (img.title) { %>
        <p style="font-size:11px;color:#6b7280;margin:4px 0 0;overflow:hidden;white-space:nowrap;
                  text-overflow:ellipsis;" title="<%= img.title %>"><%= img.title %></p>
        <% } %>
      </div>
      <% }); %>
    </div>
  </div>
</div>
<% } %>
<% } %>

<script src="https://cdn.quilljs.com/1.3.7/quill.js"></script>
<script>
(function () {
  var JOB_ID = <%= job.id %>;

  // ── Quill setup ──────────────────────────────────────────────────────────
  var quill = new Quill('#quill-editor', {
    theme: 'snow',
    modules: {
      toolbar: [
        [{ header: [1, 2, 3, 4, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        [{ indent: '-1' }, { indent: '+1' }],
        ['link', 'blockquote', 'code-block'],
        ['clean']
      ]
    }
  });

  var initialHtml = <%= JSON.stringify(keyword.content || '') %>;
  if (initialHtml) quill.clipboard.dangerouslyPasteHTML(initialHtml);

  var htmlSource = document.getElementById('html-source');
  htmlSource.value = initialHtml;

  // ── Tab switching ─────────────────────────────────────────────────────────
  var currentTab = 'visual';
  function switchTab(tab) {
    if (tab === currentTab) return;
    if (tab === 'html') {
      htmlSource.value = quill.root.innerHTML;
      document.getElementById('quill-editor').style.display = 'none';
      document.querySelector('.ql-toolbar').style.display = 'none';
      htmlSource.style.display = 'block';
      document.getElementById('tab-visual').classList.remove('active');
      document.getElementById('tab-html').classList.add('active');
    } else {
      quill.clipboard.dangerouslyPasteHTML(htmlSource.value);
      htmlSource.style.display = 'none';
      document.getElementById('quill-editor').style.display = 'block';
      document.querySelector('.ql-toolbar').style.display = 'block';
      document.getElementById('tab-html').classList.remove('active');
      document.getElementById('tab-visual').classList.add('active');
    }
    currentTab = tab;
  }
  window.switchTab = switchTab;

  // ── Form submit — sync content to hidden field ────────────────────────────
  document.getElementById('kw-form').addEventListener('submit', function () {
    var html = currentTab === 'html' ? htmlSource.value : quill.root.innerHTML;
    document.getElementById('kw-content').value = html;
  });

  // ── Category loading ──────────────────────────────────────────────────────
  var catSelect   = document.getElementById('kw-category');
  var catNewInput = document.getElementById('kw-cat-new');
  var catStatus   = document.getElementById('cat-status');
  var catCount    = document.getElementById('cat-count');
  var btnReload   = document.getElementById('btn-reload-cats');
  var currentCat  = (catSelect && catSelect.getAttribute('data-current')) || '';

  function syncCatSelect(val) {
    if (!catSelect) return;
    catSelect.value = val;
    var exists = Array.from(catSelect.options).some(function(o) { return o.value === val; });
    if (!exists && val) {
      var opt = document.createElement('option');
      opt.value = val; opt.textContent = val + ' (new)';
      catSelect.appendChild(opt);
      catSelect.value = val;
    }
  }
  window.syncCatSelect = syncCatSelect;

  if (catSelect) {
    catSelect.addEventListener('change', function () {
      if (catNewInput) catNewInput.value = catSelect.value;
    });
  }

  function setCatStatus(msg, isErr) {
    if (!catStatus) return;
    catStatus.textContent = msg;
    catStatus.style.color = isErr ? '#ef4444' : '#6b7280';
    catStatus.style.display = msg ? '' : 'none';
  }

  function loadCategories() {
    if (!catSelect) return;
    if (btnReload) btnReload.disabled = true;
    setCatStatus('Loading categories from WordPress\u2026', false);
    if (catCount) catCount.textContent = '';

    fetch('/content/' + JOB_ID + '/categories')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var cats = data.categories || [];
        var prev = catSelect.value || currentCat;
        catSelect.innerHTML = '<option value="">— none —</option>';
        cats.forEach(function (c) {
          var opt = document.createElement('option');
          opt.value = c.name;
          opt.textContent = c.name + (c.count > 0 ? ' (' + c.count + ')' : '');
          if (c.name === prev || c.name.toLowerCase() === prev.toLowerCase()) opt.selected = true;
          catSelect.appendChild(opt);
        });
        // If current value not in list, keep as "new"
        if (prev && !cats.find(function(c) { return c.name === prev; })) {
          var opt = document.createElement('option');
          opt.value = prev; opt.textContent = prev + ' (new)'; opt.selected = true;
          catSelect.appendChild(opt);
        }
        if (catNewInput) catNewInput.value = catSelect.value;
        if (catCount) catCount.textContent = cats.length ? '(' + cats.length + ')' : '';
        setCatStatus(
          cats.length ? '' : 'No categories yet \u2014 type a new name below.',
          false
        );
        if (btnReload) btnReload.disabled = false;
      })
      .catch(function (err) {
        setCatStatus('Could not load categories \u2014 check site credentials.', true);
        if (catCount) catCount.textContent = '';
        if (btnReload) btnReload.disabled = false;
      });
  }
  window.loadCategories = loadCategories;

  // Auto-load on page open
  loadCategories();

  // ── Connection check ──────────────────────────────────────────────────────
  var connDot    = document.getElementById('conn-dot');
  var connLabel  = document.getElementById('conn-label');
  var connDetail = document.getElementById('conn-detail');
  var connInfo   = document.getElementById('conn-site-info');
  var btnConn    = document.getElementById('btn-check-conn');

  function checkConnection() {
    if (!connDot) return;
    if (btnConn) btnConn.disabled = true;
    connDot.className = 'conn-dot conn-dot-spin';
    if (connLabel) connLabel.textContent = 'Checking\u2026';
    if (connInfo) connInfo.style.display = 'none';

    fetch('/content/' + JOB_ID + '/check-connection')
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (d.ok) {
          connDot.className = 'conn-dot conn-dot-ok';
          if (connLabel) connLabel.textContent = 'Connected';
          if (connInfo && d.siteInfo) {
            connInfo.innerHTML =
              '<strong>' + escHtml(d.siteInfo.name) + '</strong>' +
              (d.siteInfo.description ? ' &mdash; ' + escHtml(d.siteInfo.description) : '') +
              ' &nbsp;<a href="' + escHtml(d.siteInfo.url) + '" target="_blank" rel="noopener" ' +
              'style="font-size:11px;color:#6b7280;">' + escHtml(d.siteInfo.url) + ' &rarr;</a>' +
              (d.categories && d.categories.length
                ? '<br><span style="color:#6b7280;">' + d.categories.length + ' categories loaded</span>'
                : '');
            connInfo.style.display = '';
            // Refresh category select with fresh data
            if (d.categories && d.categories.length) {
              var prev = catSelect ? (catSelect.value || currentCat) : currentCat;
              if (catSelect) {
                catSelect.innerHTML = '<option value="">— none —</option>';
                d.categories.forEach(function (c) {
                  var opt = document.createElement('option');
                  opt.value = c.name;
                  opt.textContent = c.name + (c.count > 0 ? ' (' + c.count + ')' : '');
                  if (c.name === prev || c.name.toLowerCase() === prev.toLowerCase()) opt.selected = true;
                  catSelect.appendChild(opt);
                });
                if (prev && !d.categories.find(function(c){return c.name===prev;})) {
                  var opt2 = document.createElement('option');
                  opt2.value = prev; opt2.textContent = prev + ' (new)'; opt2.selected = true;
                  catSelect.appendChild(opt2);
                }
                if (catNewInput) catNewInput.value = catSelect.value;
                if (catCount) catCount.textContent = '(' + d.categories.length + ')';
                setCatStatus('', false);
              }
            }
          }
        } else {
          connDot.className = 'conn-dot conn-dot-err';
          if (connLabel) connLabel.textContent = 'Failed';
          if (connInfo) {
            connInfo.textContent = d.error || 'Connection failed.';
            connInfo.style.color = '#ef4444';
            connInfo.style.display = '';
          }
        }
        if (btnConn) btnConn.disabled = false;
      })
      .catch(function () {
        if (connDot) connDot.className = 'conn-dot conn-dot-err';
        if (connLabel) connLabel.textContent = 'Error';
        if (btnConn) btnConn.disabled = false;
      });
  }
  window.checkConnection = checkConnection;

  function escHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                          .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }
}());
</script>
