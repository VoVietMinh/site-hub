<div class="page-header">
  <div>
    <h1 class="page-title"><%= __('users.title') %></h1>
    <p class="page-subtitle"><%= __('users.subtitle') %></p>
  </div>
  <a href="/users/new" class="btn btn-primary"><%= __('users.create') %></a>
</div>

<div class="card">
  <% if (!admins.length) { %>
    <div class="empty"><%= __('users.empty') %></div>
  <% } else { %>
  <table class="table">
    <thead>
      <tr>
        <th><%= __('users.username') %></th>
        <th><%= __('users.email') %></th>
        <th><%= __('users.role') %></th>
        <th><%= __('users.active') %></th>
        <th><%= __('logs.time') %></th>
        <th style="text-align:right;"><%= __('users.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% admins.forEach(function(u) { %>
      <tr>
        <td><strong><%= u.username %></strong></td>
        <td><%= u.email %></td>
        <td><span class="tag tag-blue"><%= u.role %></span></td>
        <td>
          <% if (u.is_active) { %>
            <span class="tag tag-green"><%= __('users.active') %></span>
          <% } else { %>
            <span class="tag tag-red"><%= __('users.inactive') %></span>
          <% } %>
        </td>
        <td class="muted"><%= u.created_at %></td>
        <td style="text-align:right;">
          <form method="post" action="/users/<%= u.id %>/toggle-active">
            <input type="hidden" name="is_active" value="<%= u.is_active ? '0' : '1' %>" />
            <button class="btn btn-sm" type="submit"><%= u.is_active ? __('users.deactivate') : __('users.activate') %></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
