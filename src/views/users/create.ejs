<div class="page-header">
  <div>
    <h1 class="page-title"><%= __('users.create') %></h1>
    <p class="page-subtitle"><%= __('users.subtitle') %></p>
  </div>
  <a href="/users" class="btn"><%= __('common.back') %></a>
</div>

<form method="post" action="/users">
  <div class="card">
    <div class="card-body">
      <div class="form-grid">
        <div class="form-row">
          <label for="username"><%= __('users.username') %></label>
          <input id="username" name="username" type="text" required value="<%= values.username || '' %>" />
        </div>
        <div class="form-row">
          <label for="email"><%= __('users.email') %></label>
          <input id="email" name="email" type="email" required value="<%= values.email || '' %>" />
        </div>
        <div class="form-row" style="grid-column: 1 / -1;">
          <label for="password"><%= __('users.password') %></label>
          <input id="password" name="password" type="password" required minlength="8" />
          <div class="help">8–128 characters.</div>
        </div>
      </div>
    </div>
    <div class="card-body" style="border-top:1px solid var(--border);">
      <div class="form-actions">
        <button class="btn btn-primary" type="submit"><%= __('users.submit') %></button>
        <a href="/users" class="btn"><%= __('common.cancel') %></a>
      </div>
    </div>
  </div>
</form>
