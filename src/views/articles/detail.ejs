<style>
/* ── Status ───────────────────────────────────────────────────────────────── */
.status-PENDING   { background:#f3f4f6; color:#6b7280; }
.status-BUILDING  { background:#fef3c7; color:#d97706; }
.status-QUEUED    { background:#e0e7ff; color:#4338ca; }
.status-READY     { background:#dbeafe; color:#1d4ed8; }
.status-PUBLISHING{ background:#fce7f3; color:#be185d; }
.status-DONE      { background:#d1fae5; color:#065f46; }
.status-FAILED    { background:#fee2e2; color:#b91c1c; }

.error-box { background:#fee2e2; border:1px solid #fecaca; border-radius:6px; padding:10px 14px; font-size:13px; color:#b91c1c; margin-bottom:16px; }

.art-meta-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:10px; margin-bottom:16px; }
.art-meta-item { background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px; padding:10px 12px; }
.art-meta-item label { display:block; font-size:11px; color:#6b7280; text-transform:uppercase; letter-spacing:.04em; margin-bottom:4px; font-weight:600; }
.art-meta-item span { font-size:13px; font-weight:500; }

/* ── Build progress stepper ───────────────────────────────────────────────── */
.build-steps { display:flex; flex-wrap:wrap; gap:6px; margin:10px 0; }
.bstep { display:flex; align-items:center; gap:5px; padding:4px 10px; border-radius:20px; font-size:12px; font-weight:500; border:1px solid #e5e7eb; background:#f9fafb; color:#9ca3af; }
.bstep.done   { background:#d1fae5; color:#065f46; border-color:#6ee7b7; }
.bstep.active { background:#fef3c7; color:#d97706; border-color:#fde68a; }
.bstep.failed { background:#fee2e2; color:#b91c1c; border-color:#fca5a5; }
.spin { display:inline-block; width:10px; height:10px; border:2px solid #fde68a; border-top-color:#d97706; border-radius:50%; animation:spin .7s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }

/* ── Two-column layout ────────────────────────────────────────────────────── */
.detail-grid { display:grid; grid-template-columns:1fr 340px; gap:16px; align-items:start; }
@media(max-width:900px){ .detail-grid{ grid-template-columns:1fr; } }

/* ── HTML Editor tabs ─────────────────────────────────────────────────────── */
.tab-bar { display:flex; border-bottom:1px solid #e5e7eb; margin-bottom:0; }
.tab-btn { padding:8px 16px; font-size:13px; font-weight:500; cursor:pointer; border:none; background:none; color:#6b7280; border-bottom:2px solid transparent; transition:color .15s; }
.tab-btn.active { color:#6366f1; border-bottom-color:#6366f1; }
.tab-pane { display:none; }
.tab-pane.active { display:block; }
.html-textarea { width:100%; min-height:420px; padding:12px; font-family:monospace; font-size:12px; border:none; border-radius:0 0 8px 8px; resize:vertical; box-sizing:border-box; outline:none; background:#1e1e1e; color:#d4d4d4; line-height:1.6; }
.content-preview { padding:20px; max-height:500px; overflow-y:auto; font-size:14px; line-height:1.7; }
.content-preview img { max-width:100%; height:auto; border-radius:4px; margin:12px 0; }
.content-preview h2 { font-size:1.15em; margin:1.2em 0 .5em; }
.content-preview p  { margin:.6em 0; }

/* ── Right panel shared ───────────────────────────────────────────────────── */
.rcard label { display:block; font-size:12px; color:#6b7280; font-weight:500; margin-bottom:4px; }
.rcard select, .rcard input[type=datetime-local] {
  width:100%; padding:7px 10px; border:1px solid #d1d5db; border-radius:6px;
  font-size:13px; box-sizing:border-box; background:#fff; margin-bottom:10px; }
.rcard select:focus, .rcard input:focus { outline:none; border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.1); }

/* ── Images grid ──────────────────────────────────────────────────────────── */
.art-images { display:grid; grid-template-columns:repeat(auto-fill,minmax(100px,1fr)); gap:8px; }
.art-images img { width:100%; aspect-ratio:4/3; object-fit:cover; border-radius:4px; border:1px solid #e5e7eb; }

/* ── Publish history table ────────────────────────────────────────────────── */
.pub-hist-table { width:100%; border-collapse:collapse; font-size:12px; }
.pub-hist-table th { text-align:left; padding:6px 8px; border-bottom:2px solid #e5e7eb; color:#6b7280; font-weight:600; text-transform:uppercase; font-size:11px; letter-spacing:.04em; }
.pub-hist-table td { padding:6px 8px; border-bottom:1px solid #f3f4f6; vertical-align:middle; }
.pub-hist-table tr:last-child td { border-bottom:none; }
</style>

<div class="page-header">
  <div>
    <h1 class="page-title" id="art-title-heading"><%= article.title || article.keyword %></h1>
    <p class="page-subtitle">
      Article #<%= article.id %> &middot;
      <% if (site) { %><span style="color:#6366f1;"><%= site.domain %></span> &middot;<% } %>
      <span id="art-status-badge" class="tag status-<%= article.status %>"><%= article.status %></span>
      <% if (article.language && article.language !== 'English') { %>
        &middot; <span class="muted" style="font-size:12px;"><%= article.language %></span>
      <% } %>
    </p>
  </div>
  <a href="/articles<%= filters && filters.site_id ? '?site_id=' + filters.site_id : '' %>" class="btn">&larr; Back</a>
</div>

<%# -- Error ----------------------------------------------------------------- %>
<div id="art-error-box" class="error-box" style="<%= article.error_message ? '' : 'display:none;' %>">
  <% if (article.error_message) { %><strong>Error:</strong> <%= article.error_message %><% } %>
</div>

<%# -- Build progress --------------------------------------------------------- %>
<% if (['BUILDING','PUBLISHING'].includes(article.status) || article.build_step) { %>
<div class="card" style="margin-bottom:14px;" id="build-progress-card">
  <div class="card-body" style="padding:14px;">
    <div style="font-size:12px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px;">Build Progress</div>
    <div class="build-steps" id="build-steps-container"></div>
    <div id="build-step-label" style="font-size:12px;color:#d97706;margin-top:4px;"></div>
  </div>
</div>
<% } %>

<%# -- Actions panel ---------------------------------------------------------- %>
<div class="card" style="margin-bottom:14px;" id="actions-card">
  <div class="card-header"><h3>Actions</h3></div>
  <div class="card-body" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;" id="action-btns">
    <% if (article.status === 'PENDING' || article.status === 'FAILED') { %>
      <button class="btn btn-primary" onclick="doBuild()">
        <%= article.status === 'FAILED' ? '&#x21BB; Retry Build' : '&#x25B6; Build Article' %>
      </button>
    <% } %>
    <% if (article.status === 'READY' || article.status === 'DONE') { %>
      <button class="btn btn-primary" onclick="scrollToPublish()">&#x1F4E4; Publish to Site</button>
    <% } %>
    <% if (article.status === 'BUILDING' || article.status === 'PUBLISHING') { %>
      <span class="muted" style="font-size:13px;">
        <span class="spin" style="border-color:#d1d5db;border-top-color:#6366f1;margin-right:6px;"></span>
        <span id="progress-label"><%= article.status === 'PUBLISHING' ? 'Publishing&hellip;' : 'Building&hellip;' %></span>
      </span>
    <% } %>
    <% if (article.wp_post_link) { %>
      <a class="btn" href="<%= article.wp_post_link %>" target="_blank" rel="noopener">&rarr; View Post</a>
    <% } %>
    <div id="action-msg" style="font-size:13px;margin-left:4px;"></div>
  </div>
</div>

<%# -- Two-column layout ------------------------------------------------------ %>
<div class="detail-grid">

  <%# -- LEFT --------------------------------------------------------------- %>
  <div>

    <div class="card" style="margin-bottom:14px;" id="content-card">
      <div class="tab-bar">
        <button class="tab-btn active" onclick="showTab('preview', this)">Preview</button>
        <button class="tab-btn" onclick="showTab('html', this)">Edit HTML</button>
      </div>
      <div class="tab-pane active" id="tab-preview">
        <% if (article.content_html) { %>
          <div class="content-preview" id="art-content-preview"><%- article.content_html %></div>
        <% } else { %>
          <div class="content-preview" id="art-content-preview" style="color:#9ca3af;font-size:13px;">
            Content will appear here after build.
          </div>
        <% } %>
      </div>
      <div class="tab-pane" id="tab-html">
        <textarea class="html-textarea" id="html-editor" spellcheck="false" placeholder="HTML content&hellip;"><%= article.content_html || '' %></textarea>
        <div style="padding:10px;display:flex;gap:8px;border-top:1px solid #333;">
          <button class="btn btn-primary btn-sm" onclick="saveHtml()">Save HTML</button>
          <span id="html-save-msg" style="font-size:12px;line-height:26px;"></span>
        </div>
      </div>
    </div>

    <div class="card" style="margin-bottom:14px;" id="images-card">
      <div class="card-header"><h3>Images (<%= artImages.length %>)</h3></div>
      <div class="card-body" id="images-body">
        <% if (artImages.length) { %>
        <div class="art-images">
          <% artImages.forEach(function(img) { %>
          <div>
            <img src="<%= img.wp_media_url || img.source_url %>" alt="" loading="lazy" />
            <% if (img.is_featured) { %><div style="font-size:10px;color:#6b7280;text-align:center;margin-top:2px;">Featured</div><% } %>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <div style="color:#9ca3af;font-size:13px;">No images yet.</div>
        <% } %>
      </div>
    </div>

    <% if (article.outline) { %>
    <div class="card" style="margin-bottom:14px;">
      <div class="card-header"><h3>Outline</h3></div>
      <div class="card-body">
        <pre style="margin:0;font-size:12px;white-space:pre-wrap;color:#374151;line-height:1.6;"><%= article.outline %></pre>
      </div>
    </div>
    <% } %>

  </div><!-- /left -->

  <%# -- RIGHT -------------------------------------------------------------- %>
  <div>

    <%# Metadata %>
    <div class="card rcard" style="margin-bottom:14px;">
      <div class="card-header"><h3>Metadata</h3></div>
      <div class="card-body">
        <div class="art-meta-grid" style="grid-template-columns:1fr;">
          <div class="art-meta-item">
            <label>Keyword</label><span><%= article.keyword %></span>
          </div>
          <div class="art-meta-item">
            <label>Main Keyword</label><span id="art-main-kw"><%= article.main_keyword || '&mdash;' %></span>
          </div>
          <div class="art-meta-item">
            <label>Meta Description</label>
            <span id="art-meta-desc" style="font-size:12px;"><%= article.meta_description || '&mdash;' %></span>
          </div>
          <div class="art-meta-item">
            <label>Tags</label>
            <span style="font-size:12px;">
              <% var tags = article.tags ? (Array.isArray(article.tags) ? article.tags : JSON.parse(article.tags)) : []; %>
              <%= tags.join(', ') || '&mdash;' %>
            </span>
          </div>
          <div class="art-meta-item">
            <label>Tone &middot; Language</label>
            <span style="font-size:12px;"><%= article.tone %> &middot; <%= article.language || 'English' %></span>
          </div>
          <div class="art-meta-item">
            <label>Created</label>
            <span style="font-size:12px;" class="muted"><%= new Date(article.created_at).toLocaleString() %></span>
          </div>
        </div>
      </div>
    </div>

    <%# Article Settings %>
    <div class="card rcard" style="margin-bottom:14px;">
      <div class="card-header"><h3>Article Settings</h3></div>
      <div class="card-body">
        <label>Default Site <span style="color:#9ca3af;font-weight:400;">(for auto-publish)</span></label>
        <select id="settings-site">
          <option value="">— no site —</option>
          <% sites.forEach(function(s) { %>
          <option value="<%= s.id %>" <%= (article.site_id && s.id == article.site_id) ? 'selected' : '' %>><%= s.domain %></option>
          <% }); %>
        </select>

        <label>Publish Mode</label>
        <select id="pub-mode" onchange="toggleScheduled()">
          <option value="immediate" <%= article.publish_mode === 'immediate' ? 'selected' : '' %>>Immediate</option>
          <option value="scheduled" <%= article.publish_mode === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
        </select>

        <div id="sched-wrap" style="display:<%= article.publish_mode === 'scheduled' ? '' : 'none' %>;">
          <label>Scheduled At</label>
          <input type="datetime-local" id="sched-at" value="<%= article.scheduled_at ? article.scheduled_at.slice(0,16) : '' %>" />
        </div>

        <button class="btn btn-primary" style="width:100%;" onclick="saveSettings()">Save Settings</button>
        <div id="settings-msg" style="font-size:12px;margin-top:6px;"></div>
      </div>
    </div>

    <%# Publish to Site %>
    <div class="card rcard" style="margin-bottom:14px;" id="publish-panel">
      <div class="card-header"><h3>&#x1F4E4; Publish to Site</h3></div>
      <div class="card-body">
        <% if (article.status !== 'READY' && article.status !== 'DONE') { %>
          <div style="color:#9ca3af;font-size:13px;">Build the article first before publishing.</div>
        <% } else { %>
          <label>Target Site</label>
          <div style="display:flex;gap:6px;margin-bottom:10px;">
            <select id="pub-site" onchange="onPubSiteChange()" style="flex:1;margin-bottom:0;">
              <option value="">— select site —</option>
              <% sites.forEach(function(s) { %>
              <option value="<%= s.id %>" <%= (article.site_id && s.id == article.site_id) ? 'selected' : '' %>><%= s.domain %></option>
              <% }); %>
            </select>
            <button class="btn btn-sm" onclick="checkConn()" id="conn-btn" title="Test connection" style="white-space:nowrap;">&#x26A1; Test</button>
          </div>
          <div id="conn-result" style="font-size:12px;padding:6px 8px;border-radius:5px;margin-bottom:8px;display:none;"></div>

          <label>Category <span style="color:#9ca3af;font-weight:400;">(optional)</span></label>
          <select id="pub-cat" style="margin-bottom:10px;">
            <option value="">— default category —</option>
          </select>
          <div id="cat-loading" style="font-size:11px;color:#6b7280;margin-bottom:8px;display:none;">Loading categories&hellip;</div>

          <button class="btn btn-primary" style="width:100%;" onclick="doPublishToSite()" id="pub-submit-btn">&#x1F4E4; Publish Now</button>
          <div id="pub-submit-msg" style="font-size:12px;margin-top:6px;"></div>
        <% } %>
      </div>
    </div>

    <%# Publish History %>
    <div class="card" style="margin-bottom:14px;" id="publish-history-card">
      <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
        <h3>Publish History</h3>
        <button class="btn btn-sm" onclick="refreshHistory()">&#x21BB; Refresh</button>
      </div>
      <div class="card-body" style="padding:0;" id="pub-history-body">
        <% if (!publishes || !publishes.length) { %>
          <div style="padding:14px;color:#9ca3af;font-size:13px;">No publishes yet.</div>
        <% } else { %>
        <table class="pub-hist-table">
          <thead>
            <tr><th>Site</th><th>Status</th><th>Post</th><th>Date</th></tr>
          </thead>
          <tbody id="pub-hist-tbody">
          <% publishes.forEach(function(p) { %>
            <tr>
              <td style="font-weight:500;max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= p.site_domain %></td>
              <td>
                <% if (p.status === 'DONE') { %>
                  <span class="tag status-DONE" style="font-size:11px;">&#x2713; Done</span>
                <% } else if (p.status === 'FAILED') { %>
                  <span class="tag status-FAILED" style="font-size:11px;" title="<%= (p.error_message || '').replace(/"/g, '&quot;') %>">&#x2717; Failed</span>
                <% } else { %>
                  <span class="tag status-PUBLISHING" style="font-size:11px;">Publishing&hellip;</span>
                <% } %>
              </td>
              <td>
                <% if (p.wp_post_link) { %>
                  <a href="<%= p.wp_post_link %>" target="_blank" rel="noopener" style="font-size:12px;">&rarr; View</a>
                <% } else { %><span class="muted">&mdash;</span><% } %>
              </td>
              <td class="muted" style="white-space:nowrap;font-size:11px;"><%= new Date(p.created_at).toLocaleDateString() %></td>
            </tr>
          <% }); %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>

  </div><!-- /right -->
</div><!-- /detail-grid -->

<script>
(function () {
  var articleId = <%- article.id %>;
  var pollTimer = null;

  function escHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* ── Tabs ─────────────────────────────────────────────────────────────────── */
  window.showTab = function (name, btn) {
    document.querySelectorAll('.tab-pane').forEach(function (p) { p.classList.remove('active'); });
    document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
  };

  /* ── Build steps ──────────────────────────────────────────────────────────── */
  var ALL_STEPS = ['title','research','outline','sections','images','metadata','stitching'];
  var STEP_LABELS = { title:'Title', research:'Research', outline:'Outline',
    sections:'Sections', images:'Images', metadata:'Metadata', stitching:'Stitch' };

  function stepOrderOf(step) {
    if (!step) return -1;
    if (step.startsWith('sections:')) return ALL_STEPS.indexOf('sections');
    return ALL_STEPS.indexOf(step);
  }

  function renderSteps(currentStep) {
    var container = document.getElementById('build-steps-container');
    var labelEl   = document.getElementById('build-step-label');
    if (!container) return;
    var curIdx = stepOrderOf(currentStep);
    var html = '';
    ALL_STEPS.forEach(function (s, idx) {
      var cls = 'bstep';
      if (idx < curIdx) cls += ' done';
      else if (idx === curIdx) cls += ' active';
      var spinner = (idx === curIdx) ? '<span class="spin"></span> ' : '';
      html += '<div class="' + cls + '">' + spinner + STEP_LABELS[s] + '</div>';
    });
    container.innerHTML = html;
    if (labelEl) {
      if (currentStep && currentStep.startsWith('sections:'))
        labelEl.textContent = 'Writing sections ' + currentStep.replace('sections:','') + '\u2026';
      else if (currentStep === 'failed') labelEl.textContent = 'Build failed';
      else if (currentStep) labelEl.textContent = currentStep.charAt(0).toUpperCase() + currentStep.slice(1) + '\u2026';
      else labelEl.textContent = '';
    }
  }

  var initStatus = '<%- article.status %>';
  var initStep   = '<%- article.build_step || "" %>';
  if (initStatus === 'BUILDING' || initStep) renderSteps(initStep || null);

  /* ── Status poll ──────────────────────────────────────────────────────────── */
  function updateUI(a) {
    var badge = document.getElementById('art-status-badge');
    if (badge) { badge.className = 'tag status-' + a.status; badge.textContent = a.status; }
    var errBox = document.getElementById('art-error-box');
    if (errBox) {
      if (a.error_message) { errBox.innerHTML = '<strong>Error:</strong> ' + escHtml(a.error_message); errBox.style.display = ''; }
      else errBox.style.display = 'none';
    }
    if (a.title) { var h = document.getElementById('art-title-heading'); if (h) h.textContent = a.title; }
    if (a.main_keyword) { var mk = document.getElementById('art-main-kw'); if (mk) mk.textContent = a.main_keyword; }
    if (a.meta_description) { var md = document.getElementById('art-meta-desc'); if (md) md.textContent = a.meta_description; }
    var progCard = document.getElementById('build-progress-card');
    if (a.status === 'BUILDING' || a.build_step) {
      if (progCard) progCard.style.display = '';
      renderSteps(a.build_step || null);
    }
    if (a.status === 'DONE' || a.status === 'FAILED' || a.status === 'READY') {
      clearInterval(pollTimer); pollTimer = null;
      if (a.content_html) {
        var prev = document.getElementById('art-content-preview');
        if (prev) prev.innerHTML = a.content_html;
        var editor = document.getElementById('html-editor');
        if (editor) editor.value = a.content_html;
      }
      setTimeout(function () { window.location.reload(); }, 1500);
    }
  }

  function startPoll() {
    if (pollTimer) return;
    pollTimer = setInterval(function () {
      fetch('/api/articles/' + articleId + '/status')
        .then(function (r) { return r.json(); })
        .then(function (data) { if (data.article) updateUI(data.article); })
        .catch(function () {});
    }, 2500);
  }
  if (initStatus === 'BUILDING' || initStatus === 'PUBLISHING') startPoll();

  /* ── Build / Retry ────────────────────────────────────────────────────────── */
  function setMsg(msg, err) {
    var el = document.getElementById('action-msg');
    if (el) { el.textContent = msg; el.style.color = err ? '#dc2626' : '#16a34a'; }
  }

  window.doBuild = function () {
    var isRetry = initStatus === 'FAILED';
    var url = '/api/articles/' + articleId + (isRetry ? '/retry' : '/build');
    var body = { publish_mode: document.getElementById('pub-mode') ? document.getElementById('pub-mode').value : 'immediate' };
    var schedAt = document.getElementById('sched-at');
    if (schedAt && schedAt.value) body.scheduled_at = new Date(schedAt.value).toISOString();
    setMsg('Starting build\u2026');
    fetch(url, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.error) { setMsg('Error: ' + data.error, true); return; }
        setMsg('Build started\u2026');
        var badge = document.getElementById('art-status-badge');
        if (badge) { badge.className = 'tag status-BUILDING'; badge.textContent = 'BUILDING'; }
        var actionBtns = document.getElementById('action-btns');
        if (actionBtns) actionBtns.innerHTML = '<span class="muted" style="font-size:13px;"><span class="spin" style="border-color:#d1d5db;border-top-color:#6366f1;margin-right:6px;"></span>Building\u2026</span><div id="action-msg"></div>';
        var progCard = document.getElementById('build-progress-card');
        if (!progCard) {
          var c = document.createElement('div'); c.className='card'; c.style.marginBottom='14px'; c.id='build-progress-card';
          c.innerHTML='<div class="card-body" style="padding:14px;"><div style="font-size:12px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px;">Build Progress</div><div class="build-steps" id="build-steps-container"></div><div id="build-step-label" style="font-size:12px;color:#d97706;margin-top:4px;"></div></div>';
          document.getElementById('actions-card').insertAdjacentElement('afterend', c);
        } else progCard.style.display = '';
        startPoll();
      })
      .catch(function (err) { setMsg('Request failed: ' + err.message, true); });
  };

  /* ── Scroll to publish panel ──────────────────────────────────────────────── */
  window.scrollToPublish = function () {
    var el = document.getElementById('publish-panel');
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  /* ── Publish to a specific site ───────────────────────────────────────────── */
  window.doPublishToSite = function () {
    var pubSiteEl = document.getElementById('pub-site');
    var catEl     = document.getElementById('pub-cat');
    var msgEl     = document.getElementById('pub-submit-msg');
    var btn       = document.getElementById('pub-submit-btn');
    var siteId    = pubSiteEl ? pubSiteEl.value : '';
    var catId     = catEl ? catEl.value : '';

    if (!siteId) {
      if (msgEl) { msgEl.textContent = 'Select a site first.'; msgEl.style.color = '#d97706'; }
      return;
    }
    if (btn) { btn.disabled = true; btn.textContent = 'Publishing\u2026'; }
    if (msgEl) msgEl.textContent = '';

    var body = { site_id: siteId };
    if (catId) body.category_id = catId;

    fetch('/api/articles/' + articleId + '/publish', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (btn) { btn.disabled = false; btn.textContent = '\uD83D\uDCE4 Publish Now'; }
        if (data.error) {
          if (msgEl) { msgEl.textContent = '\u2717 ' + data.error; msgEl.style.color = '#dc2626'; }
        } else {
          if (msgEl) { msgEl.textContent = '\u2713 Published!'; msgEl.style.color = '#16a34a'; }
          setTimeout(refreshHistory, 600);
          var badge = document.getElementById('art-status-badge');
          if (badge) { badge.className = 'tag status-DONE'; badge.textContent = 'DONE'; }
        }
      })
      .catch(function (err) {
        if (btn) { btn.disabled = false; btn.textContent = '\uD83D\uDCE4 Publish Now'; }
        if (msgEl) { msgEl.textContent = 'Request failed: ' + err.message; msgEl.style.color = '#dc2626'; }
      });
  };

  /* ── Refresh publish history ──────────────────────────────────────────────── */
  window.refreshHistory = function () {
    fetch('/api/articles/' + articleId + '/publishes')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var body  = document.getElementById('pub-history-body');
        if (!body || !data.publishes) return;
        if (!data.publishes.length) {
          body.innerHTML = '<div style="padding:14px;color:#9ca3af;font-size:13px;">No publishes yet.</div>';
          return;
        }
        function statusBadge(p) {
          if (p.status === 'DONE')       return '<span class="tag status-DONE" style="font-size:11px;">\u2713 Done</span>';
          if (p.status === 'FAILED')     return '<span class="tag status-FAILED" style="font-size:11px;" title="' + escHtml(p.error_message) + '">\u2717 Failed</span>';
          return '<span class="tag status-PUBLISHING" style="font-size:11px;">Publishing\u2026</span>';
        }
        var rows = '';
        data.publishes.forEach(function (p) {
          rows += '<tr>' +
            '<td style="font-weight:500;max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + escHtml(p.site_domain) + '</td>' +
            '<td>' + statusBadge(p) + '</td>' +
            '<td>' + (p.wp_post_link ? '<a href="' + escHtml(p.wp_post_link) + '" target="_blank" rel="noopener" style="font-size:12px;">\u2192 View</a>' : '<span class="muted">\u2014</span>') + '</td>' +
            '<td class="muted" style="white-space:nowrap;font-size:11px;">' + new Date(p.created_at).toLocaleDateString() + '</td>' +
            '</tr>';
        });
        body.innerHTML = '<table class="pub-hist-table"><thead><tr><th>Site</th><th>Status</th><th>Post</th><th>Date</th></tr></thead><tbody id="pub-hist-tbody">' + rows + '</tbody></table>';
      })
      .catch(function () {});
  };

  /* ── HTML editor ──────────────────────────────────────────────────────────── */
  window.saveHtml = function () {
    var html = document.getElementById('html-editor').value;
    var msg  = document.getElementById('html-save-msg');
    msg.textContent = 'Saving\u2026'; msg.style.color = '#6b7280';
    fetch('/api/articles/' + articleId + '/update', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ content_html: html })
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.error) { msg.textContent = 'Error: ' + data.error; msg.style.color='#dc2626'; return; }
        msg.textContent = '\u2713 Saved'; msg.style.color = '#16a34a';
        var prev = document.getElementById('art-content-preview');
        if (prev) prev.innerHTML = html;
        setTimeout(function () { msg.textContent = ''; }, 2000);
      })
      .catch(function (err) { msg.textContent = 'Failed: ' + err.message; msg.style.color='#dc2626'; });
  };

  /* ── Article settings ─────────────────────────────────────────────────────── */
  window.toggleScheduled = function () {
    var mode = document.getElementById('pub-mode').value;
    document.getElementById('sched-wrap').style.display = mode === 'scheduled' ? '' : 'none';
  };

  window.saveSettings = function () {
    var siteId  = document.getElementById('settings-site').value;
    var mode    = document.getElementById('pub-mode').value;
    var schedAt = document.getElementById('sched-at');
    var msg     = document.getElementById('settings-msg');
    var body = { publish_mode: mode, site_id: siteId ? parseInt(siteId, 10) : null };
    if (schedAt && schedAt.value) body.scheduled_at = new Date(schedAt.value).toISOString();
    if (msg) { msg.textContent = 'Saving\u2026'; msg.style.color = '#6b7280'; }
    fetch('/api/articles/' + articleId + '/update', {
      method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body)
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!msg) return;
        if (data.error) { msg.textContent = 'Error: ' + data.error; msg.style.color='#dc2626'; return; }
        msg.textContent = '\u2713 Saved'; msg.style.color = '#16a34a';
        setTimeout(function () { msg.textContent = ''; }, 2000);
      })
      .catch(function (err) { if (msg) { msg.textContent = 'Failed: ' + err.message; msg.style.color='#dc2626'; } });
  };

  /* ── Check WP connection ──────────────────────────────────────────────────── */
  window.checkConn = function () {
    var pubSiteEl = document.getElementById('pub-site');
    var siteId    = pubSiteEl ? pubSiteEl.value : '';
    var resEl     = document.getElementById('conn-result');
    var btn       = document.getElementById('conn-btn');
    if (!siteId) {
      if (resEl) { resEl.style.display=''; resEl.style.background='#fef3c7'; resEl.style.color='#d97706'; resEl.textContent='Select a site first.'; }
      return;
    }
    if (btn) { btn.disabled = true; btn.textContent = '\u2026'; }
    if (resEl) { resEl.style.display=''; resEl.style.background='#f3f4f6'; resEl.style.color='#6b7280'; resEl.textContent='Testing\u2026'; }
    fetch('/api/articles/sites/' + siteId + '/check-connection', { method:'POST', headers:{'Content-Type':'application/json'} })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (btn) { btn.disabled=false; btn.textContent='\u26A1 Test'; }
        if (!resEl) return;
        if (data.ok) {
          resEl.style.background='#d1fae5'; resEl.style.color='#065f46';
          resEl.textContent='\u2713 Connected (' + data.via + ')';
        } else {
          resEl.style.background='#fee2e2'; resEl.style.color='#b91c1c';
          resEl.textContent='\u2717 ' + (data.error || 'Failed') + ' (' + data.via + ')';
        }
      })
      .catch(function (err) {
        if (btn) { btn.disabled=false; btn.textContent='\u26A1 Test'; }
        if (resEl) { resEl.style.background='#fee2e2'; resEl.style.color='#b91c1c'; resEl.textContent='Request failed: ' + err.message; }
      });
  };

  /* ── Category loader ──────────────────────────────────────────────────────── */
  function loadCategories(siteId, selectedCatId) {
    var catSel  = document.getElementById('pub-cat');
    var catLoad = document.getElementById('cat-loading');
    if (!catSel) return;
    if (!siteId) { catSel.innerHTML = '<option value="">— default category —</option>'; return; }
    catSel.disabled = true;
    if (catLoad) catLoad.style.display = '';
    fetch('/api/articles/sites/' + siteId + '/categories')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        catSel.disabled = false;
        if (catLoad) catLoad.style.display = 'none';
        var cats = data.categories || [];
        catSel.innerHTML = '<option value="">— default category —</option>';
        cats.forEach(function (c) {
          var opt = document.createElement('option');
          opt.value = c.id; opt.textContent = c.name;
          if (selectedCatId && c.id == selectedCatId) opt.selected = true;
          catSel.appendChild(opt);
        });
      })
      .catch(function () {
        catSel.disabled = false;
        if (catLoad) { catLoad.textContent = 'Could not load categories.'; catLoad.style.display = ''; }
      });
  }

  window.onPubSiteChange = function () {
    var siteId = document.getElementById('pub-site').value;
    loadCategories(siteId, null);
    // Clear conn result when site changes
    var resEl = document.getElementById('conn-result');
    if (resEl) resEl.style.display = 'none';
  };

  // Load categories on page load if a site is pre-selected in the publish panel
  var initPubSiteId = <%- article.site_id || 'null' %>;
  if (initPubSiteId) loadCategories(initPubSiteId, <%- article.category_id || 'null' %>);

}());
</script>
