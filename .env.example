# =============================================================================
# ee-control-panel — environment variables reference
#
# Copy this file to .env and fill in real values before starting the panel.
# Never commit .env to git — it is listed in .gitignore.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_NAME=Pelxa Control Panel

# ── Session ───────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-string

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# In Docker Compose the host is the postgres service name ("postgres").
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgres://panel_user:panelpass123@postgres:5432/panel_db
# Password must match POSTGRES_PASSWORD in docker-compose.yml
POSTGRES_PASSWORD=panelpass123

# ── Default Super Admin (seeded automatically on first run) ───────────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_EMAIL=admin@example.com

# ── Localization ──────────────────────────────────────────────────────────────
DEFAULT_LOCALE=vi
SUPPORTED_LOCALES=vi,en

# ── EasyEngine / WordPress CLI ────────────────────────────────────────────────
# Path of the `ee` binary on the host (not inside the container).
EE_BINARY=ee

# When EE_OVER_SSH=true every `ee` and `wp` call is wrapped in:
#   ssh -i $EE_SSH_KEY_PATH $EE_SSH_USER@$EE_SSH_HOST <cmd>
# The panel container holds a read-only private key; the host needs the
# matching public key in /root/.ssh/authorized_keys.
EE_OVER_SSH=true
EE_SSH_HOST=host.docker.internal
EE_SSH_USER=root
EE_SSH_KEY_PATH=/app/secrets/ee_key

# ── WordPress REST API ────────────────────────────────────────────────────────
# Internal host Docker uses to reach the WordPress containers on the host.
# Leave as host.docker.internal unless your Docker networking differs.
WP_API_HOST=host.docker.internal

# ── AI Provider — Google Gemini ───────────────────────────────────────────────
# Get an API key at https://aistudio.google.com/app/apikey
# Set AI_PROVIDER=mock to skip real API calls (returns placeholder data).
AI_PROVIDER=gemini
AI_API_KEY=
# Model name — gemini-2.0-flash is fast and cost-effective for article work.
GEMINI_MODEL=gemini-2.5-flash

# ── Google Custom Search Engine (CSE) ─────────────────────────────────────────
# Used for SERP research and image search during article building.
# Create a CSE at https://programmablesearchengine.google.com/
# Get an API key at https://console.cloud.google.com/ → Custom Search JSON API
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ── Article pipeline tuning ───────────────────────────────────────────────────
# Number of outline sections generated per article (default 9).
ARTICLE_DEFAULT_OUTLINE_COUNT=9
# Default writing tone injected into section prompts.
ARTICLE_DEFAULT_TONE=natural, humanize
# Target word range per section (used as guidance in the prompt).
ARTICLE_SECTION_WORDS_MIN=500
ARTICLE_SECTION_WORDS_MAX=700
# Delay (ms) between WP tag creation calls to avoid REST API rate limits.
TAG_CREATE_DELAY_MS=3000

# ── n8n Integration (optional) ────────────────────────────────────────────────
# Webhook URL and token for triggering external SEO / publishing workflows.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=

# ── Image search — Serper.dev (legacy, superseded by Google CSE) ──────────────
# Only needed if you use the old Serper-based image search path.
SERPER_API_KEY=
