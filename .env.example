# ===== App =====
NODE_ENV=development
PORT=3000
APP_NAME=EE Control Panel

# ===== Session =====
SESSION_SECRET=change-this-to-a-long-random-string

# ===== Database (SQLite) =====
DB_PATH=./data/app.db

# ===== Default Super Admin (seeded on first run) =====
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_EMAIL=admin@example.com

# ===== Localization =====
DEFAULT_LOCALE=vi
SUPPORTED_LOCALES=vi,en

# ===== EasyEngine =====
# In production on Ubuntu, EE is invoked via the host's `ee` binary. The container
# bind-mounts the docker socket so EE inside the container can spawn site stacks.
EE_BINARY=ee

# ===== n8n Integration (optional) =====
# Webhook URL that triggers the SEO publishing workflow.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=

# ===== Image API (placeholder) =====
SERPAPI_KEY=
GOOGLE_CSE_ID=
GOOGLE_CSE_KEY=

# ===== AI Provider (placeholder for outline + article generation) =====
AI_PROVIDER=mock
AI_API_KEY=
