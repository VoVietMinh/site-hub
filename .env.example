# ===== App =====
NODE_ENV=development
PORT=3000
APP_NAME=Pelxa Control Panel

# ===== Session =====
SESSION_SECRET=change-this-to-a-long-random-string

# ===== Database (SQLite) =====
DB_PATH=./data/app.db

# ===== Default Super Admin (seeded on first run) =====
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_EMAIL=admin@example.com

# ===== Localization =====
DEFAULT_LOCALE=vi
SUPPORTED_LOCALES=vi,en

# ===== EasyEngine =====
# Path of the `ee` binary on the *host* (not inside the container).
EE_BINARY=ee

# When EE_OVER_SSH=true, every `ee` and `wp` call is wrapped in
# `ssh -i $EE_SSH_KEY_PATH $EE_SSH_USER@$EE_SSH_HOST <cmd>`.
# This is the production setup on Ubuntu: the panel container holds a
# read-only private key, the host has the matching pubkey in its
# /root/.ssh/authorized_keys, and EasyEngine itself never enters the container.
EE_OVER_SSH=true
EE_SSH_HOST=host.docker.internal
EE_SSH_USER=root
EE_SSH_KEY_PATH=/app/secrets/ee_key

# ===== n8n Integration (optional) =====
# Webhook URL that triggers the SEO publishing workflow.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=

# ===== Image API — Serper.dev (https://serper.dev) =====
SERPER_API_KEY=

# ===== AI Provider — set to "gemini" for Google Gemini 1.5 Flash =====
# Leave AI_PROVIDER=mock to use placeholder data (no API key needed).
AI_PROVIDER=gemini
AI_API_KEY=
