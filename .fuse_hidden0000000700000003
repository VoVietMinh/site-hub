#\!/usr/bin/env bash
# =============================================================================
# deploy.sh -- zero-downtime deploy for ee-control-panel (PostgreSQL edition)
#
# Strategy
# --------
# 1. Fetch + hard-reset to origin/main  (no merge conflicts ever)
# 2. BUILD the new image while the old container is still serving
# 3. SWAP: docker compose up --no-build  (< 2 s visible downtime)
# 4. Wait for /healthz HEALTHCHECK to pass
#
# Sessions survive the swap because they live in PostgreSQL (shared service).
# =============================================================================
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

COMPOSE_FILES="-f docker-compose.yml -f docker-compose.ee.yml"
CONTAINER="ee-control-panel"
BRANCH="${1:-main}"
HEALTH_TIMEOUT=90

# -- 1. Git sync (conflict-proof) ---------------------------------------------
echo ">>  Syncing with origin/$BRANCH ..."
git rm --cached data/app.db-shm data/app.db-wal data/app.db 2>/dev/null || true
git fetch origin
git reset --hard origin/$BRANCH

# -- 2. Build new image (old container keeps serving) -------------------------
echo ">>  Building new image ..."
docker compose $COMPOSE_FILES build panel

# -- 3. Fast swap (postgres stays up, only panel restarts) --------------------
echo ">>  Swapping panel container ..."
docker compose $COMPOSE_FILES up -d --no-build panel

# -- 4. Wait for health check -------------------------------------------------
echo ">>  Waiting for container health (timeout: ${HEALTH_TIMEOUT}s) ..."
ELAPSED=0
while true; do
  STATUS=$(docker inspect --format='{{.State.Health.Status}}' "$CONTAINER" 2>/dev/null || echo "missing")
  if [ "$STATUS" = "healthy" ]; then
    echo "OK  Container is healthy."
    break
  fi
  if [ "$STATUS" = "unhealthy" ]; then
    echo "ERR Container UNHEALTHY. Recent logs:"
    docker logs --tail 40 "$CONTAINER"
    exit 1
  fi
  if [ "$ELAPSED" -ge "$HEALTH_TIMEOUT" ]; then
    echo "ERR Health check timed out (${HEALTH_TIMEOUT}s, status: $STATUS). Logs:"
    docker logs --tail 40 "$CONTAINER"
    exit 1
  fi
  sleep 2; ELAPSED=$((ELAPSED + 2))
  echo "    ... $STATUS (${ELAPSED}s)"
done

echo ""
echo "OK  Deploy complete. Panel is live."
